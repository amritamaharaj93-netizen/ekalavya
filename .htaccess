DirectoryIndex index.php
Options -MultiViews
RewriteEngine On

# 1. Professional Catalog Routing (Slugs)
RewriteRule ^course/([^/]+)$ course-detail.php?slug=$1 [L,QSA]
RewriteRule ^scholarship/([^/]+)$ scholarship-detail.php?slug=$1 [L,QSA]
RewriteRule ^test-series/([^/]+)$ test-series-detail.php?slug=$1 [L,QSA]
RewriteRule ^study-material/([^/]+)$ study-material-detail.php?slug=$1 [L,QSA]

# 2. Exclude physical files/directories from further rules
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Internal mapping: /courses -> courses.php
# This handles extensionless URLs without needing RewriteBase
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L,QSA]

# 4. Optional: Remove .php extension from browser bar (Redirect)
# Only if the user visits a .php file directly
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php [NC]
RewriteRule ^ %1 [R=301,L]
