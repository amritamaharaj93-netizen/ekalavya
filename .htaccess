DirectoryIndex index.php
Options -MultiViews
RewriteEngine On
RewriteBase /eklavya/

# 1. Professional Catalog Routing (Slugs)
RewriteRule ^course/([^/]+)$ course-detail.php?slug=$1 [L,QSA]
RewriteRule ^scholarship/([^/]+)$ scholarship-detail.php?slug=$1 [L,QSA]
RewriteRule ^test-series/([^/]+)$ test-series-detail.php?slug=$1 [L,QSA]
RewriteRule ^study-material/([^/]+)$ study-material-detail.php?slug=$1 [L,QSA]

# 2. Exclude physical files/directories from further rules
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Remove .php extension (Browser Redirect)
# Use RewriteBase aware redirect
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php [NC]
RewriteRule ^ %1 [R=301,L,NE]

# 4. Internal mapping: /courses -> courses.php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# 5. Handle index redirect
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*/)index [NC]
RewriteRule ^ %1 [R=301,L]
